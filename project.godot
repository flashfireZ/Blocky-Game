; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blocky Battle"
run/main_scene="res://scenes/minigames/BlockGame_Multiplayer/SplashScreen.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/image="uid://bygvw5svgfl5b"
config/icon="res://icon.svg"

[autoload]

GameData="*uid://d1s1qjgp2pjrb"
FirebaseManager="*uid://cy83cnaehuhm1"
Transition="*res://scenes/ui/Transition.tscn"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/resizable=false
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[global_group]

BuildingSystem=""

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
rendering_device/driver.android="opengl3"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
